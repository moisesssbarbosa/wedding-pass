generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String
}

model Convidado {
  id             Int     @id @default(autoincrement())
  nome           String
  cpf            String  @unique
  mesa           Int
  status_checkin Boolean @default(false)
}