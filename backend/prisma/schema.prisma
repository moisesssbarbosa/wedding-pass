generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String 
  email String @unique
  senha String
  cargo String 
}

model Convidado {
  id             Int     @id @default(autoincrement())
  nome           String
  email          String  @unique
  telefone       String
  mesa           Int
  status_checkin Boolean @default(false)
}